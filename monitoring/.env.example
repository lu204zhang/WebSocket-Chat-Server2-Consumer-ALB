# RabbitMQ (collect-rabbitmq-metrics.sh)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
SAMPLE_INTERVAL_SEC=10
DURATION_MIN=15
# OUTPUT_FILE= (leave unset for auto records/rabbitmq-YYYYMMDD-HHMMSS.csv, or set e.g. records/rabbitmq-threads10.csv)

# ALB (collect-alb-metrics.sh)
ALB_ARN=arn:aws:elasticloadbalancing:us-east-1:ACCOUNT:loadbalancer/app/chat-ws-alb/ID
AWS_REGION=us-east-1

# EC2 (collect-system-metrics.sh)
INSTANCE_IDS=i-0abc123,i-0def456
